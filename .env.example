# .env.example
DEBUG=True
ENV=sandbox

# Ozon credentials (заполняй из кабинета)
OZON_CLIENT_ID=your_client_id_here
OZON_API_KEY=your_api_key_here

# Wildberries credentials
WB_API_KEY=your_wb_api_key_here

# Backend settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=true

# CORS settings
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:5500"]
